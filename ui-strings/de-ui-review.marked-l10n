%@" = "Abschnittszusammenfassungen:

%@";
# EN: Section summaries:\n\n%@

"Select text in the preview first, or use Summarize Document." = "Wähle zuerst Text in der Vorschau aus oder verwende Dokument zusammenfassen.";
# EN: Select text in the preview first, or use Summarize Document.

"Select text in the preview first." = "Wähle zuerst Text in der Vorschau aus.";
# EN: Select text in the preview first.

"Starting…" = "Starte…";
# EN: Starting…

"Summaries and answers appear here, just above your question." = "Zusammenfassungen und Antworten erscheinen hier, direkt über deiner Frage.";
# EN: Summaries and answers appear here, just above your question.

"Summarize Document" = "Dokument zusammenfassen";
# EN: Summarize Document

"Summarize Selection" = "Auswahl zusammenfassen";
# EN: Summarize Selection

"Summarize the following excerpt in three to five sentences." = "Fasse den folgenden Auszug in drei bis fünf Sätzen zusammen.";
# EN: Summarize the following excerpt in three to five sentences.

"Summarize this section in two or three sentences." = "Fasse diesen Abschnitt in zwei oder drei Sätzen zusammen.";
# EN: Summarize this section in two or three sentences.

"Summarizing" = "Zusammenfassen";
# EN: Summarizing

"Summarizing document…" = "Dokument wird zusammengefasst…";
# EN: Summarizing document…

"Summarizing selection…" = "Auswahl wird zusammengefasst…";
# EN: Summarizing selection…

"Thinking…" = "Denke nach…";
# EN: Thinking…

"This Mac does not support Apple Intelligence." = "Dieser Mac unterstützt Apple Intelligence nicht.";
# EN: This Mac does not support Apple Intelligence.

"This document has no text to analyze." = "Dieses Dokument enthält keinen Text zum Analysieren.";
# EN: This document has no text to analyze.

"This document is too large for a single request. Try selecting a smaller passage or ask a narrower question." = "Dieses Dokument ist für eine einzelne Anfrage zu groß. Wähle einen kürzeren Abschnitt aus oder stelle eine präzisere Frage.";
# EN: This document is too large for a single request. Try selecting a smaller passage or ask a narrower question.

"Turn on Apple Intelligence in System Settings to use Ask About Document." = "Aktiviere Apple Intelligence in den Systemeinstellungen, um Dokument befragen zu nutzen.";
# EN: Turn on Apple Intelligence in System Settings to use Ask About Document.

"Turn on Apple Intelligence in System Settings to use this feature." = "Aktiviere Apple Intelligence in den Systemeinstellungen, um diese Funktion zu nutzen.";
# EN: Turn on Apple Intelligence in System Settings to use this feature.

"Uses on-device Apple Intelligence." = "Verwendet lokale Apple Intelligence.";
# EN: Uses on-device Apple Intelligence.

"What's on your mind?" = "Was möchtest du wissen?";
# EN: What's on your mind?

"Write a cohesive summary of the full document in four to eight sentences." = "Schreibe eine zusammenhängende Zusammenfassung des gesamten Dokuments in vier bis acht Sätzen.";
# EN: Write a cohesive summary of the full document in four to eight sentences.

"You help someone review a document open in Marked, a Markdown preview app.
Use only the document text provided in the prompt. Be accurate and concise.
If the text does not contain enough information, say so briefly.
Write all responses in %@." = "Du hilfst jemandem, ein in Marked geöffnetes Dokument zu prüfen, einer Markdown-Vorschau-App.
Verwende nur den im Prompt bereitgestellten Dokumenttext. Sei präzise und knapp.
Wenn der Text nicht genug Informationen enthält, sage das kurz.
Schreibe alle Antworten auf %@.";
# EN: You help someone review a document open in Marked, a Markdown preview app.\nUse only the document text provided in the prompt. Be accurate and concise.\nIf the text does not contain enough information, say so briefly.\nWrite all responses in %@.


