# EN: Choose which side equation numbers appear on.

"tooltip.minimumRepeats" = "Nombre minimum de mots consécutifs répétés avant d'être surlignés.";
# EN: Minimum number of consecutive repeated words before highlighting.

"tooltip.noLabels" = "Génère des ID d'en-tête basés sur le contenu des balises h1-h6.";
