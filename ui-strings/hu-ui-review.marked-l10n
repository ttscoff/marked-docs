# DRAFT: A beállítások frissítéséhez importáljon egy .markedprefs fájlt.

"tooltip.shouldDetectCritic" = "";
# EN: Enable CriticMarkup processing automatically when appropriate syntax is detected.
# DRAFT: A megfelelő szintaxis észlelésekor engedélyezze a CriticMarkup feldolgozást.

"tooltip.shouldHighlightMarkupErrors" = "";
# EN: Highlight broken Markdown links and other markup that may have converted improperly.
# DRAFT: Jelölje ki a hibás Markdown linkeket és egyéb jelöléseket, amelyek esetleg helytelenül konvertáltak.

"tooltip.showDiffs" = "";
# EN: Show small gutter markers to highlight detected edit locations.
# DRAFT: Kis ereszcsatorna-jelölők megjelenítése az észlelt szerkesztési helyek kiemeléséhez.

"tooltip.showEditMarker" = "";
# EN: Show a marker at the most recent edit point (first or last diff, depending on "Reverse diff order" setting).
# DRAFT: Jelölő megjelenítése a legutóbbi szerkesztési pontnál (első vagy utolsó eltérés, a "Diff sorrend fordított sorrendje" beállítástól függően).

"tooltip.showFullPathInWindowTitle" = "";
# EN: Show the full path to the current file instead of just its filename.
# DRAFT: Mutassa meg az aktuális fájl teljes elérési útját a fájlnév helyett.

"tooltip.showPageBreaksInPreview" = "";
# EN: Show a light dashed line where breaks are inserted with <!--BREAK--> syntax or by checking auto-break options in Export settings.
# DRAFT: Mutasson világos szaggatott vonalat, ahol a töréseket <!--BREAK--> szintaxissal szúrja be, vagy ellenőrizze az automatikus törés opciókat az Exportálási beállításokban.

"tooltip.showSelectionWordCount" = "";
# EN: Show a word count popup for the selected text whenever a selection is made.
# DRAFT: A kiválasztott szöveg szószámláló előugró ablakának megjelenítése, amikor kijelölés történik.

"tooltip.showStylePicker" = "";
# EN: Shows the style picker in the bottom bar of the preview window.
# DRAFT: Megjeleníti a stílusválasztót az előnézeti ablak alsó sávjában.

"tooltip.showWordCount" = "";
# EN: Show word count (and statistics button) in the bottom bar of the preview window.
# DRAFT: A szószám (és a statisztika gomb) megjelenítése az előnézeti ablak alsó sávjában.

"tooltip.statusBarShowsCharacterCount" = "";
# EN: The counter in the status bar shows characters instead of words.
# DRAFT: Az állapotsor számlálója szavak helyett karaktereket mutat.

"tooltip.stripMMDMetadata" = "";
# EN: Removes MultiMarkdown metadata from the top of the document. This is useful if you're not using MultiMarkdown, but want to make use of header metadata without it appearing in your document. Metadata is read in before this happens, so you can still use Marked-specific metadata instructions and other variables are available.
# DRAFT: Eltávolítja a MultiMarkdown metaadatokat a dokumentum tetejéről. Ez akkor hasznos, ha nem használja a MultiMarkdown kifejezést, de szeretné használni a fejléc metaadatait anélkül, hogy azok megjelennének a dokumentumban. A metaadatokat a rendszer beolvassa, mielőtt ez megtörténne, így továbbra is használhatja a Marked-specifikus metaadat-utasításokat, és más változók is rendelkezésre állnak.

"tooltip.styleHashTags" = "";
# EN: Tags receive special capsule styling in the preview.
# DRAFT: A címkék különleges kapszula stílust kapnak az előnézetben.

"tooltip.summaryMdIsGitBook" = "";
# EN: Interpret files named SUMMARY.md as index files for GitBook documentation.
# DRAFT: Értelmezze a SUMMARY.md nevű fájlokat indexfájlként a GitBook dokumentációhoz.

"tooltip.suppressPrintLinks" = "";
# EN: Removes formatting (underline and color) from links when printing.
# DRAFT: Nyomtatáskor eltávolítja a formázást (aláhúzás és színes) a hivatkozásokról.

"tooltip.swapCommandE" = "";
# EN: If disabled, ⌘E will open the default Editor. If this is enabled, ⌘E will invoke "Find with Selection" and begin a search and ⌘⌥E will open the editor.
# DRAFT: Ha le van tiltva, a ⌘E megnyitja az alapértelmezett szerkesztőt. Ha ez be van kapcsolva, a ⌘E meghívja a „Keresés kijelöléssel” parancsot, keresést indít, az ⌘⌥E pedig megnyitja a szerkesztőt.

"tooltip.syncPreviewToSourceScroll" = "";
# EN: Sync the source code view scroll position with the Preview scroll
# DRAFT: Szinkronizálja a forráskód nézet görgetési pozícióját az Előnézet görgetéssel

"tooltip.syncSpeedReadWithScrollPosition" = "";
# EN: Start Speed Read from the current viewport and scroll the preview as playback advances.
# DRAFT: Indítsa el az olvasási sebességet az aktuális nézetből, és görgessen az előnézeten a lejátszás előrehaladtával.

"tooltip.syntaxHighlight" = "";
# EN: Highlight code blocks with highlight.js.
# DRAFT: Jelölje ki a kódblokkokat a highlight.js segítségével.

"tooltip.syntaxHighlightOnlyLang" = "";
# EN: Apply styling only to fenced code blocks with a language specified, e.g. ```js
