"tooltip.codeCanWrap" = "";
# EN: If checked, themes are allowed to cause wrapping within pre>code blocks. If a theme doesn't provide wrapping, overflowing text will scroll horizontally.
# DRAFT: Ha be van jelölve, a témák elő->kód blokkokba burkolózhatnak. Ha egy téma nem biztosít tördelést, a túlcsorduló szöveg vízszintesen gördül.

"tooltip.codeIsPoetry" = "";
# EN: If checked, tab-indented, fenced or included code is displayed as poetry instead of a code block. (No syntax highlighting, and special styling depending on the theme.)
