"tooltip.toctype1" = "";
# EN: Choose the type of bullet for root indentation level.
# DRAFT: Válassza ki a felsorolás típusát a gyökér behúzási szintjéhez.

"tooltip.toctype2" = "";
# EN: Choose the type of bullet for first indentation level.
# DRAFT: Válassza ki a felsorolás típusát az első behúzási szinthez.

"tooltip.toctype3" = "";
# EN: Choose the type of bullet for second indentation level.
# DRAFT: Válassza ki a felsorolás típusát a második behúzási szinthez.

"tooltip.toctype4" = "";
# EN: Choose the type of bullet for third indentation level.
# DRAFT: Válassza ki a felsorolás típusát a harmadik behúzási szinthez.

"tooltip.toctype5" = "";
# EN: Choose the type of bullet for fourth indentation level.
# DRAFT: Válassza ki a felsorolás típusát a negyedik behúzási szinthez.

"tooltip.toctype6" = "";
# EN: Choose the type of bullet for fifth indentation level. Additional indentation levels will default to this setting.
# DRAFT: Válassza ki a felsorolás típusát az ötödik behúzási szinthez. A további behúzási szintek alapértelmezés szerint erre a beállításra vonatkoznak.

"tooltip.topPrintMargin" = "";
# EN: Define print margins (specified in points).
# DRAFT: Nyomtatási margók meghatározása (pontokban megadva).

"tooltip.trackCustomCSS" = "";
# EN: When this is enabled, Marked will watch the current CSS file for disk changes, aiding in custom style editing and web development.
# DRAFT: Ha ez be van kapcsolva, a Marked figyeli az aktuális CSS-fájlt a lemezmódosítások miatt, ezzel segítve az egyéni stílusú szerkesztést és a webfejlesztést.

"tooltip.transparentInBackground" = "";
# EN: Fade the window when it's not focused. Use the slider to set the opacity.
# DRAFT: Halványítsa el az ablakot, ha nincs fókuszban. Használja a csúszkát az átlátszóság beállításához.

"tooltip.treatAdditionalSyntaxAsCritic" = "";
# EN: Render ==highlight== and ~~delete~~ as CriticMarkup.
# DRAFT: Az ==highlight== és a ~~delete~~ megjelenítése CriticMarkup-ként.

"tooltip.useFirstH1AsPrintTitle" = "";
# EN: If no title metadata is provided, use the first H1 header as the print/save title on transient previews.
# DRAFT: Ha nem ad meg cím metaadatait, használja az első H1 fejlécet nyomtatási/mentési címként az átmeneti előnézeteknél.

"tooltip.useSystemFindPasteboard" = "";
# EN: By default, Marked loads the last search text used in any other application. Uncheck this to ignore that text.
# DRAFT: Alapértelmezés szerint a Marked a bármely más alkalmazásban használt legutóbbi keresési szöveget tölti be. Törölje a jelölést a szöveg figyelmen kívül hagyásához.

"tooltip.validateLinksOnLoad" = "";
# EN: Validate URLs on document load and refresh. Only displays results if there are errors.
# DRAFT: Érvényesítse az URL-eket a dokumentum betöltésekor és frissítésekor. Csak akkor jeleníti meg az eredményeket, ha hibák vannak.

"tooltip.wikiLinkDefaultExtension" = "";
# EN: Default extension for wiki-linked files. If this is set, you can omit the extension from a [[wiki link]].
# DRAFT: A wiki-hivatkozású fájlok alapértelmezett kiterjesztése. Ha ez be van állítva, kihagyhatja a kiterjesztést a [[wikilink]]-ből.

"tooltip.yamlHandling" = "";
# EN: Determine how to handle YAML front matter. Ignore will leave it in place for the processor to handle, or you can convert it to MMD metadata or remove it entirely.
# DRAFT: Határozza meg, hogyan kell kezelni a YAML frontügyet. Az Ignore funkció a helyén hagyja a processzor számára, vagy átalakíthatja MMD metaadatokká, vagy teljesen eltávolíthatja.

