"No document text to analyze." = "分析するドキュメントのテキストがありません。";
# EN: No document text to analyze.

"Outline" = "アウトライン";
# EN: Outline

"Outlining" = "アウトライン作成中";
# EN: Outlining

"Preparing" = "準備中";
# EN: Preparing

