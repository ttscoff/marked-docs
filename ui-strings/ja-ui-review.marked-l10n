Document text:

" = "質問: %@

ドキュメントのテキスト:

";
# EN: Question: %@\n\nDocument text:\n\n

"Section %ld: %@" = "セクション %ld: %@";
# EN: Section %ld: %@

"Section summaries:

%@" = "セクションの要約:

%@";
# EN: Section summaries:\n\n%@

"Select text in the preview first, or use Summarize Document." = "まずプレビューでテキストを選択するか、「ドキュメントの要約」を使用してください。";
# EN: Select text in the preview first, or use Summarize Document.

"Select text in the preview first." = "まずプレビューでテキストを選択してください。";
# EN: Select text in the preview first.

"Starting…" = "開始しています…";
# EN: Starting…

"Summaries and answers appear here, just above your question." = "要約と回答は、質問のすぐ上に表示されます。";
# EN: Summaries and answers appear here, just above your question.

"Summarize Document" = "ドキュメントの要約";
# EN: Summarize Document

"Summarize Selection" = "選択内容の要約";
# EN: Summarize Selection

"Summarize the following excerpt in three to five sentences." = "次の抜粋を 3 ～ 5 文で要約してください。";
# EN: Summarize the following excerpt in three to five sentences.

"Summarize this section in two or three sentences." = "このセクションを 2 ～ 3 文で要約してください。";
# EN: Summarize this section in two or three sentences.

"Summarizing" = "要約中";
# EN: Summarizing

"Summarizing document…" = "ドキュメントを要約しています…";
# EN: Summarizing document…

"Summarizing selection…" = "選択範囲を要約しています…";
# EN: Summarizing selection…

"Thinking…" = "考えています…";
# EN: Thinking…

"This Mac does not support Apple Intelligence." = "この Mac は Apple Intelligence をサポートしていません。";
# EN: This Mac does not support Apple Intelligence.

"This document has no text to analyze." = "このドキュメントには分析するテキストがありません。";
# EN: This document has no text to analyze.

"This document is too large for a single request. Try selecting a smaller passage or ask a narrower question." = "このドキュメントは 1 回のリクエストには大きすぎます。短い範囲を選択するか、絞り込んだ質問をしてください。";
# EN: This document is too large for a single request. Try selecting a smaller passage or ask a narrower question.

"Turn on Apple Intelligence in System Settings to use Ask About Document." = "「ドキュメントについて質問」を使用するには、システム設定で Apple Intelligence をオンにしてください。";
# EN: Turn on Apple Intelligence in System Settings to use Ask About Document.

"Turn on Apple Intelligence in System Settings to use this feature." = "この機能を使用するには、システム設定で Apple Intelligence をオンにしてください。";
# EN: Turn on Apple Intelligence in System Settings to use this feature.

"Uses on-device Apple Intelligence." = "デバイス上の Apple Intelligence を使用します。";
# EN: Uses on-device Apple Intelligence.

"What's on your mind?" = "何について知りたいですか？";
# EN: What's on your mind?

"Write a cohesive summary of the full document in four to eight sentences." = "ドキュメント全体の一貫した要約を 4 ～ 8 文で書いてください。";
# EN: Write a cohesive summary of the full document in four to eight sentences.

"You help someone review a document open in Marked, a Markdown preview app.
Use only the document text provided in the prompt. Be accurate and concise.
If the text does not contain enough information, say so briefly.
Write all responses in %@." = "あなたは、Markdown プレビューアプリ Marked で開いているドキュメントのレビューを手伝います。
プロンプトで与えられたドキュメントのテキストのみを使用してください。正確かつ簡潔に答えてください。
テキストに十分な情報が含まれていない場合は、その旨を簡潔に伝えてください。
すべての回答を %@ で記述してください。";
# EN: You help someone review a document open in Marked, a Markdown preview app.\nUse only the document text provided in the prompt. Be accurate and concise.\nIf the text does not contain enough information, say so briefly.\nWrite all responses in %@.


