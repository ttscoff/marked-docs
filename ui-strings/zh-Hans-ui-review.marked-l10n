# EN: Select text in the preview first.

"Starting…" = "正在开始…";
# EN: Starting…

"Summaries and answers appear here, just above your question." = "摘要和回答会显示在这里，位于问题上方。";
# EN: Summaries and answers appear here, just above your question.

"Summarize Document" = "总结文档";
# EN: Summarize Document

"Summarize Selection" = "总结所选内容";
# EN: Summarize Selection

"Summarize the following excerpt in three to five sentences." = "用三到五句话总结以下摘录。";
# EN: Summarize the following excerpt in three to five sentences.

"Summarize this section in two or three sentences." = "用两到三句话总结本节。";
# EN: Summarize this section in two or three sentences.

"Summarizing" = "正在总结";
# EN: Summarizing

